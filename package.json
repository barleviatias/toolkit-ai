{
  "name": "toolkit-ai",
  "version": "2.1.0",
  "description": "CLI with React Ink TUI for managing AI skills, agents, MCPs, and bundles across Claude Code, Codex, Copilot, and Cursor",
  "bin": {
    "toolkit-ai": "bin/ai-toolkit.mjs",
    "ai-toolkit": "bin/ai-toolkit.mjs",
    "toolkit": "bin/ai-toolkit.mjs"
  },
  "files": [
    "bin/ai-toolkit.mjs",
    "resources/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "generate:catalog": "node scripts/generate-catalog.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node tests/run.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "toolkit",
    "ai-toolkit",
    "skills",
    "agents",
    "ai-agents",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "codex",
    "copilot",
    "cursor",
    "cursor-ai",
    "cli",
    "ink",
    "tui",
    "developer-tools",
    "plugin-manager",
    "agent-framework",
    "prompt-engineering",
    "skill-management",
    "typescript",
    "configuration"
  ],
  "author": "Bar Leviatias",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/barleviatias/toolkit-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barleviatias/toolkit-ai.git"
  },
  "bugs": {
    "url": "https://github.com/barleviatias/toolkit-ai/issues"
  },
  "dependencies": {}
}
