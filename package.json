{
  "name": "toolkit-ai",
  "version": "2.0.6",
  "description": "CLI with React Ink TUI for managing AI skills, agents, MCPs, and bundles across Claude Code, Codex, Copilot, and Cursor",
  "bin": {
    "toolkit-ai": "bin/ai-toolkit.mjs",
    "ai-toolkit": "bin/ai-toolkit.mjs",
    "toolkit": "bin/ai-toolkit.mjs"
  },
  "files": [
    "bin/ai-toolkit.mjs",
    "resources/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "generate:catalog": "node scripts/generate-catalog.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node tests/run.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "toolkit",
    "skills",
    "agents",
    "mcp",
    "claude",
    "codex",
    "copilot",
    "cursor",
    "cli",
    "ink"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barleviatias/toolkit-ai.git"
  },
  "dependencies": {}
}
